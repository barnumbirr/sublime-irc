# ── KICK events ───────────────────────────────────────

# Pattern A: kicked from #channel by operator
00:01 -!- baduser was kicked from #linux by chanop [spam]
#         ^^^^^^^ entity.name.tag.nickname.irc
#                 ^^^^^^^^^^ keyword.other.kick.irc
#                            ^^^^ keyword.operator.word.irc
#                                 ^ punctuation.definition.channel.irc
#                                  ^^^^^ constant.other.channel.irc
#                                        ^^ keyword.operator.word.irc
#                                           ^^^^^^ entity.name.tag.nickname.irc
#                                                  ^ punctuation.section.brackets.begin.irc
#                                                   ^^^^ string.unquoted.quit-message.irc
#                                                       ^ punctuation.section.brackets.end.irc

# Pattern A: "has been kicked" variant
00:01 -!- baduser has been kicked from #linux by chanop (spam)
#         ^^^^^^^ entity.name.tag.nickname.irc
#                 ^^^^^^^^^^^^^^^ keyword.other.kick.irc
#                                 ^^^^ keyword.operator.word.irc
#                                      ^ punctuation.definition.channel.irc
#                                       ^^^^^ constant.other.channel.irc
#                                             ^^ keyword.operator.word.irc
#                                                ^^^^^^ entity.name.tag.nickname.irc

# Pattern B: kicked by operator from #channel
[12:34] * baduser was kicked by chanop from #linux (spam)
#         ^^^^^^^ entity.name.tag.nickname.irc
#                 ^^^^^^^^^^ keyword.other.kick.irc
#                            ^^ keyword.operator.word.irc
#                               ^^^^^^ entity.name.tag.nickname.irc
#                                      ^^^^ keyword.operator.word.irc
#                                           ^ punctuation.definition.channel.irc
#                                            ^^^^^ constant.other.channel.irc
#                                                  ^ punctuation.section.parens.begin.irc
#                                                   ^^^^ string.unquoted.quit-message.irc
#                                                       ^ punctuation.section.parens.end.irc

