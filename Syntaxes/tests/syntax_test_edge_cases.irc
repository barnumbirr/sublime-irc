# ── mIRC session events ──────────────────────────────

[12:34] * Now talking in #linux
#         ^^^ meta.event.irc keyword.other.join.irc
#             ^^^^^^^ meta.event.irc keyword.other.join.irc
#                     ^^ meta.event.irc keyword.operator.word.irc
#                        ^ punctuation.definition.channel.irc
#                         ^^^^^ constant.other.channel.irc

[12:34] * Topic is 'Welcome to #linux'
#         ^^^^^ meta.event.irc keyword.other.topic.irc
#               ^^ meta.event.irc keyword.operator.word.irc
#                  ^ meta.event.irc punctuation.definition.string.begin.irc
#                   ^^^^^^^^^^^^^^^^^ meta.event.irc string.quoted.single.topic.irc
#                                    ^ meta.event.irc punctuation.definition.string.end.irc

[12:34] * Set by sysop on Fri Jun 14 19:32:11 2024
#         ^^^ meta.event.irc keyword.other.topic.irc
#             ^^ meta.event.irc keyword.operator.word.irc
#                ^^^^^ meta.event.irc entity.name.tag.nickname.irc
#                      ^^ meta.event.irc keyword.operator.word.irc

# ── Negative assertions ────────────────────────────────

# Mid-line time-like text should not be a timestamp
[12:34] <ab> said 12:34 yesterday
#                 ^^^^^ - meta.date

# Bare # in prose should not be a channel (requires at least 1 char after prefix)
[12:34] <ab> issue # description
#                  ^ - punctuation.definition.channel

# Event markers in message text should not trigger event highlighting
[12:34] <ab> 5 * 3 = 15
#              ^ - punctuation.definition.event
#                ^ - meta.event

[12:34] <ab> well -- anyway
#                 ^^ - punctuation.definition.event
