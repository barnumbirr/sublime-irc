# ── === event marker ───────────────────────────────────

00:01 === foo joined #bar
#     ^^^ punctuation.definition.event.irc
#         ^^^ meta.event.irc entity.name.tag.nickname.irc
#             ^^^^^^ meta.event.irc keyword.other.join.irc
#                    ^ punctuation.definition.channel.irc
#                     ^^^ constant.other.channel.irc

# ── Padded nicknames (irssi right-pads with spaces) ───

00:01 < nick> hello
#     ^ punctuation.definition.reference.nickname.begin.irc
#       ^^^^ entity.name.tag.nickname.irc
#           ^ punctuation.definition.reference.nickname.end.irc

00:01 <@op> hello
#     ^ punctuation.definition.reference.nickname.begin.irc
#      ^ variable.annotation.prefix.irc
#       ^^ entity.name.tag.nickname.irc
#         ^ punctuation.definition.reference.nickname.end.irc

# ── Prefixed nicknames ─────────────────────────────────

[12:34] <@op> test
#        ^ variable.annotation.prefix.irc
#         ^^ entity.name.tag.nickname.irc
#           ^ punctuation.definition.reference.nickname.end.irc

[12:34] <+voice> test
#        ^ variable.annotation.prefix.irc
#         ^^^^^ entity.name.tag.nickname.irc

[12:34] <%half> test
#        ^ variable.annotation.prefix.irc
#         ^^^^ entity.name.tag.nickname.irc

[12:34] <~owner> test
#        ^ variable.annotation.prefix.irc
#         ^^^^^ entity.name.tag.nickname.irc

[12:34] <&admin> test
#        ^ variable.annotation.prefix.irc
#         ^^^^^ entity.name.tag.nickname.irc

# ── Unprefixed nick still works ────────────────────────

[12:34] <nick> test
#       ^ punctuation.definition.reference.nickname.begin.irc
#        ^^^^ entity.name.tag.nickname.irc
#            ^ punctuation.definition.reference.nickname.end.irc

