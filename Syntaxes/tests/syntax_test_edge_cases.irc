# SYNTAX TEST "Packages/IRC Syntax/Syntaxes/IRC.sublime-syntax"

# ── Single-character nicknames ────────────────────────────

[12:34] <a> test
#        ^ entity.name.tag.nickname.irc

[12:34] <X> test
#        ^ entity.name.tag.nickname.irc

# ── RFC 2812 special characters in nicknames ─────────────

[12:34] <nick[away]> brb
#        ^^^^^^^^^^ entity.name.tag.nickname.irc
#                  ^ punctuation.definition.reference.nickname.end.irc

[12:34] <{nick}> test
#        ^^^^^^ entity.name.tag.nickname.irc

# ── Mismatched brackets are not timestamps ───────────────

[12:34 <ab> no closing bracket
# <- - meta.date.irc

12:34] <ab> no opening bracket
# <- - meta.date.irc

# ── Channel variations ───────────────────────────────────

00:01 -!- foo joined ##linux
#                    ^ punctuation.definition.channel.irc
#                     ^^^^^^ constant.other.channel.irc

00:01 -!- foo joined &local
#                    ^ punctuation.definition.channel.irc
#                     ^^^^^ constant.other.channel.irc

# ── Hostmask in join/quit events ────────────────────────

00:01 -!- foo [user@host.net] has joined #bar
#             ^ meta.event.irc punctuation.definition.hostmask.begin.irc
#              ^^^^ string.unquoted.hostmask.irc
#                  ^ punctuation.separator.email.irc
#                   ^^^^ string.unquoted.hostmask.irc
#                       ^ punctuation.separator.domain.irc
#                        ^^^ string.unquoted.hostmask.irc
#                           ^ punctuation.definition.hostmask.end.irc
#                             ^^^^ meta.event.irc keyword.operator.word.irc
#                                 ^^^^^^ meta.event.irc keyword.other.join.irc

00:01 -!- foo (user@host.net) has quit (bye)
#             ^ meta.event.irc punctuation.definition.hostmask.begin.irc
#              ^^^^ string.unquoted.hostmask.irc
#                  ^ punctuation.separator.email.irc
#                   ^^^^ string.unquoted.hostmask.irc
#                       ^ punctuation.separator.domain.irc
#                        ^^^ string.unquoted.hostmask.irc
#                           ^ punctuation.definition.hostmask.end.irc
#                             ^^^^ meta.event.irc keyword.operator.word.irc
#                                 ^^^^ meta.event.irc keyword.other.quit.irc
#                                      ^ punctuation.section.parens.begin.irc
#                                       ^^^ string.unquoted.quit-message.irc
#                                          ^ punctuation.section.parens.end.irc

# ── URL excludes trailing punctuation ────────────────────

[12:34] <ab> https://x.co, ok
#            ^^^^^^^^^^^^ markup.underline.link.irc
#                         ^ - markup.underline.link

[12:34] <ab> (https://x.co) ok
#             ^^^^^^^^^^^^ markup.underline.link.irc
#                          ^ - markup.underline.link

[12:34] <ab> https://x.co. ok
#            ^^^^^^^^^^^^ markup.underline.link.irc
#                        ^ - markup.underline.link

[12:34] <ab> https://x.co! ok
#            ^^^^^^^^^^^^ markup.underline.link.irc
#                        ^ - markup.underline.link

# ── Quit reasons in both bracket styles ──────────────────

00:01 -!- foo has quit [Ping timeout: 480 seconds]
#             ^^^^ keyword.operator.word.irc
#                 ^^^^ keyword.other.quit.irc
#                      ^ punctuation.section.brackets.begin.irc
#                       ^^^^^^^^^^^^^^^^^^^^^^^^^ string.unquoted.quit-message.irc
#                                                ^ punctuation.section.brackets.end.irc

00:01 -!- foo has quit (Quit: bye)
#             ^^^^ keyword.operator.word.irc
#                 ^^^^ keyword.other.quit.irc
#                      ^ punctuation.section.parens.begin.irc
#                       ^^^^^^^^^ string.unquoted.quit-message.irc
#                                ^ punctuation.section.parens.end.irc

# ── Topic changes ────────────────────────────────────────

00:01 -!- foo changed the topic of #bar to: hi!
#         ^^^ entity.name.tag.nickname.irc
#             ^^^^^^^^^^^^^^^^^^^^ keyword.operator.word.irc
#                                  ^ punctuation.definition.channel.irc
#                                   ^^^ constant.other.channel.irc
#                                       ^^ keyword.operator.word.irc
#                                         ^ punctuation.separator.key-value.irc
#                                           ^^^ string.unquoted.topic.irc

# ── Topic with URL ─────────────────────────────────────

00:01 -!- foo changed the topic of #bar to: https://x.co info
#                                           ^^^^^^^^^^^^ markup.underline.link.irc
#                                           ^^^^^^^^^^^^ string.unquoted.topic.irc

# ── Topic display ──────────────────────────────────────

00:01 -!- Topic for #linux: Linux support
#         ^^^^^ meta.event.irc keyword.other.topic.irc
#               ^^^ meta.event.irc keyword.operator.word.irc
#                   ^ punctuation.definition.channel.irc
#                    ^^^^^ constant.other.channel.irc
#                         ^ meta.event.irc punctuation.separator.key-value.irc
#                           ^^^^^^^^^^^^^ meta.event.irc string.unquoted.topic.irc

