# ── http URL ───────────────────────────────────────────

[12:34] <ab> http://example.com ok
#            ^^^^^^^^^^^^^^^^^^ markup.underline.link.irc

# ── URL with path ─────────────────────────────────────

[12:34] <ab> https://example.com/path/to/page ok
#            ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ markup.underline.link.irc

# ── URL with query string ─────────────────────────────

[12:34] <ab> https://example.com/path?q=1&r=2 ok
#            ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ markup.underline.link.irc

# ── URL with port ─────────────────────────────────────

[12:34] <ab> https://example.com:8080/path ok
#            ^^^^^^^^^^^^^^^^^^^^^^^^^^^^ markup.underline.link.irc

# ── URL with fragment ─────────────────────────────────

[12:34] <ab> https://example.com/page#section ok
#            ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ markup.underline.link.irc
#                                    ^ - punctuation.definition.channel

# ── URL trailing ? ────────────────────────────────────

[12:34] <ab> https://x.co? ok
#            ^^^^^^^^^^^^ markup.underline.link.irc
#                        ^ - markup.underline.link

# ── URL before ] ──────────────────────────────────────

[12:34] <ab> [https://x.co] ok
#             ^^^^^^^^^^^^ markup.underline.link.irc
#                         ^ - markup.underline.link

# ── URL trailing : and ; ───────────────────────────────

[12:34] <ab> https://x.co: ok
#            ^^^^^^^^^^^^ markup.underline.link.irc
#                        ^ - markup.underline.link

[12:34] <ab> https://x.co; ok
#            ^^^^^^^^^^^^ markup.underline.link.irc
#                        ^ - markup.underline.link

