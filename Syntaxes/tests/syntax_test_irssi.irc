# SYNTAX TEST "Packages/IRC Syntax/Syntaxes/IRC.sublime-syntax"

00:01 <ab> hi
# <- meta.date.irc constant.numeric.value.irc
#^ constant.numeric.value.irc
# ^ punctuation.separator.date.irc
#  ^^ constant.numeric.value.irc
#    ^ - meta.date
#     ^ punctuation.definition.reference.nickname.begin.irc
#      ^^ entity.name.tag.nickname.irc
#        ^ punctuation.definition.reference.nickname.end.irc

00:01 -!- foo joined #bar
#     ^^^ punctuation.definition.event.irc
#        ^ - punctuation.definition.event
#         ^^^ meta.event.irc entity.name.tag.nickname.irc
#             ^^^^^^ meta.event.irc keyword.other.join.irc
#                    ^ punctuation.definition.channel.irc
#                     ^^^ constant.other.channel.irc

00:01 -!- foo has quit [bye]
#         ^^^ meta.event.irc entity.name.tag.nickname.irc
#             ^^^^ meta.event.irc keyword.operator.word.irc
#                 ^^^^ meta.event.irc keyword.other.quit.irc
#                      ^ meta.event.irc punctuation.section.brackets.begin.irc
#                       ^^^ meta.event.irc string.unquoted.quit-message.irc
#                          ^ meta.event.irc punctuation.section.brackets.end.irc

00:01 -!- foo is "Foo" on #bar
#         ^^^ entity.name.tag.nickname.irc
#             ^^ keyword.operator.word.irc
#                ^ punctuation.definition.string.begin.irc
#                 ^^^ string.quoted.double.realname.irc
#                    ^ punctuation.definition.string.end.irc
#                      ^^ keyword.operator.word.irc
#                         ^ punctuation.definition.channel.irc
#                          ^^^ constant.other.channel.irc

00:01 -!- old is now known as new
#         ^^^ entity.name.tag.nickname.irc
#             ^^^^^^^^^^^^^^^ keyword.operator.word.irc
#                             ^^^ entity.name.tag.nickname.irc

00:01 <ab> https://x.co ok
#          ^^^^^^^^^^^^ markup.underline.link.irc
#                       ^^ - markup.underline.link

# ── KICK events ───────────────────────────────────────

00:01 -!- baduser was kicked from #linux by chanop [spam]
#         ^^^^^^^ entity.name.tag.nickname.irc
#                 ^^^^^^^^^^ keyword.other.kick.irc
#                            ^^^^ keyword.operator.word.irc
#                                 ^ punctuation.definition.channel.irc
#                                  ^^^^^ constant.other.channel.irc
#                                        ^^ keyword.operator.word.irc
#                                           ^^^^^^ entity.name.tag.nickname.irc
#                                                  ^ punctuation.section.brackets.begin.irc
#                                                   ^^^^ string.unquoted.quit-message.irc
#                                                       ^ punctuation.section.brackets.end.irc

# ── MODE changes ──────────────────────────────────────

00:01 -!- mode/#linux [+o chanop] by ChanServ
#         ^^^^ keyword.other.mode.irc
#             ^ punctuation.separator.path.irc
#              ^ punctuation.definition.channel.irc
#               ^^^^^ constant.other.channel.irc
#                     ^ punctuation.section.brackets.begin.irc
#                      ^^^^^^^^^ variable.parameter.mode-string.irc
#                               ^ punctuation.section.brackets.end.irc
#                                 ^^ keyword.operator.word.irc
#                                    ^^^^^^^^ entity.name.tag.nickname.irc

# ── Action/emote text ─────────────────────────────────

00:09  * nick agrees with everyone
#        ^^^^ meta.event.irc entity.name.tag.nickname.irc
#             ^^^^^^^^^^^^^^^^^^^^ meta.event.irc string.unquoted.action.irc
